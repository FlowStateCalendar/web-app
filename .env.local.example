# Supabase (same project as iOS app)
# Get these from your Supabase project: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google Classroom (optional): for Connect/Sync in Settings
# Create OAuth 2.0 credentials in Google Cloud Console, enable Classroom API, add redirect URI: {origin}/auth/google-classroom/callback
# Also set these as Supabase Edge Function secrets for sync-google-classroom: supabase secrets set GOOGLE_CLASSROOM_CLIENT_ID=... GOOGLE_CLASSROOM_CLIENT_SECRET=...
GOOGLE_CLASSROOM_CLIENT_ID=
GOOGLE_CLASSROOM_CLIENT_SECRET=
